# ─── Gateway ─────────────────────────────────────────────────────────────────
PORT=3000
# CORS: lista separada por comas de orígenes permitidos. Usa "*" solo en dev.
# En prod: la URL del frontend (ej. https://eciexpress.example.com).
CORS_ORIGINS=http://localhost:4200

# ─── Firebase Admin SDK ───────────────────────────────────────────────────────
# Opción A (recomendada en Container Apps via Secret): JSON del service account.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Opción B: ruta al archivo JSON del service account en el filesystem.
# firebase-admin lo lee automáticamente desde esta variable.
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/firebase-service-account.json

# ─── URLs de servicios internos ───────────────────────────────────────────────
# En prod: FQDN privados de Container Apps (DNS interno del entorno).
# Ejemplo prod: https://identity.internal.<env>.azurecontainerapps.io
# En Docker Compose local: usar nombres de servicio (ej. http://identity-service:3001).
IDENTITY_SERVICE_URL=http://identity-service:3001
PRODUCTS_SERVICE_URL=http://products-service:3002
ORDERS_SERVICE_URL=http://orders-service:3000
FINANCIAL_SERVICE_URL=http://financial-service:3004
FULFILLMENT_SERVICE_URL=http://fulfillment-service:3000
NOTIFICATIONS_SERVICE_URL=http://notifications-service:3006
REPORTING_SERVICE_URL=http://reporting-service:3000

# ─── Redis ────────────────────────────────────────────────────────────────────
# Usado para: (1) caché de enriquecimiento, (2) rate limiting distribuido.
# Si no se define, AMBAS funciones degradan a memoria (válido para dev local sin Docker).
#
# Entorno 1 — dev local sin Redis:  comentar REDIS_URL (o dejarlo vacío)
# Entorno 2 — dev local con Docker: REDIS_URL=redis://localhost:6379
# Entorno 3 — Azure Cache for Redis (prod):
#   REDIS_URL=rediss://<name>.redis.cache.windows.net:6380?password=<access-key>
REDIS_URL=redis://localhost:6379

# ─── Caché de enriquecimiento ─────────────────────────────────────────────────
# TTL en segundos del caché firebaseUid → {userId, roles, storeId, status}.
# Intencionalmente corto: si un admin cambia el rol/tienda de un usuario,
# el dato viejo expira en este tiempo sin necesidad de invalidación activa.
ENRICHMENT_CACHE_TTL_SECONDS=60

# ─── Rate limiting ────────────────────────────────────────────────────────────
# 60 peticiones por ventana de 60 segundos (= 1 req/seg promedio).
# Con Redis: conteo compartido entre réplicas del gateway.
# Sin Redis: conteo por instancia (puede ser más permisivo en multi-instancia).
THROTTLE_LIMIT=60
THROTTLE_TTL_MS=60000
